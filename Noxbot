FAQ = [
    ("Apakah akun aman?", "✅ Aman! Kami pakai metode family/sharing yang tidak mempengaruhi akun utama kamu."),
    ("Berapa lama proses aktivasi?", "⚡ Aktivasi cepat, maksimal 1x24 jam setelah pembayaran konfirmasi."),
