def jam_kerja():
    jam_sekarang = datetime.now().hour
    return JAM_BUKA <= jam_sekarang < JAM_TUTUP

def pesan_tutup():
    return (
        f"🌙 *Toko sedang tutup*\n\n"
        f"Jam operasional kami: {JAM_BUKA:02d}.00 - {JAM_TUTUP:02d}.00 WIB\n\n"
        f"Pesanmu sudah kami catat ya! Admin akan membalas saat toko buka. "
        f"Atau kamu bisa tinggalkan pesan di sini 😊"
    )

