logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

def jam_kerja():
    return JAM_BUKA <= datetime.now().hour < JAM_TUTUP

def pesan_tutup():
    return f"🌙 *Toko sedang tutup*\n\nJam operasional: {JAM_BUKA:02d}.00 - {JAM_TUTUP:02d}.00 WIB\n\nPesanmu sudah kami catat! Admin akan membalas saat toko buka 😊"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    keyboard = [
        [InlineKeyboardButton("🛒 Lihat Produk", callback_data="menu_produk")],
        [InlineKeyboardButton("❓ FAQ", callback_data="menu_faq"), InlineKeyboardButton("📞 Hubungi Admin", callback_data="menu_admin")],
        [InlineKeyboardButton("🔥 Cara Order", callback_data="menu_order")],
    ]
    await update.message.reply_text(f"Halo *{user.first_name}* 👋\n\nSelamat datang di *{NAMA_TOKO}*!\nLangganan premium harga terjangkau & bergaransi 🔥\n\nPilih menu di bawah ya:", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def menu_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    keyboard = [[InlineKeyboardButton(f"{p['emoji']} {p['nama']}", callback_data=f"produk_{k}")] for k, p in PRODUK.items()]
    keyboard.append([InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")])
    await query.edit_message_text("🛒 *Pilih produk yang kamu mau:*", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def detail_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    key = query.data.replace("produk_", "")
    produk = PRODUK.get(key)
    harga_text = "\n".join([f"  • {d}: *{h}*" for d, h in produk['harga'].items()])
    keyboard = [[InlineKeyboardButton(f"✅ Order {produk['nama']}", callback_data=f"order_{key}")], [InlineKeyboardButton("🔙 Kembali", callback_data="menu_produk")]]
    await query.edit_message_text(f"{produk['emoji']} *{produk['nama']}*\n\n_{produk['deskripsi']}_\n\n💰 *Harga:*\n{harga_text}\n\nTap tombol di bawah untuk order!", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def order_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    key = query.data.replace("order_", "")
    produk = PRODUK.get(key)
    user = query.from_user
    if not jam_kerja():
        await query.edit_message_text(pesan_tutup(), parse_mode="Markdown")
        await context.bot.send_message(ADMIN_ID, f"📬 Order di luar jam kerja!\nUser: {user.full_name} (@{user.username})\nProduk: {produk['nama']}")
        return
    await context.bot.send_message(ADMIN_ID, f"🔔 *ORDER BARU!*\n\n👤 {user.full_name}\n🆔 @{user.username}\n📦 {produk['emoji']} {produk['nama']}\n\nSegera hubungi customer!", parse_mode="Markdown")
    keyboard = [[InlineKeyboardButton("🔙 Menu Utama", callback_data="menu_utama")]]
    await query.edit_message_text(f"✅ *Order {produk['nama']} diterima!*\n\nAdmin akan segera menghubungi kamu 🙏", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def menu_faq(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    faq_text = "".join([f"*{i}. {p}*\n{j}\n\n" for i, (p, j) in enumerate(FAQ, 1)])
    keyboard = [[InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")]]
    await query.edit_message_text(f"❓ *FAQ*\n\n{faq_text}", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def menu_admin(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    keyboard = [[InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")]]
    await query.edit_message_text(f"📞 *Hubungi Admin*\n\n👤 Admin: {ADMIN_USERNAME}\n\nJam operasional: {JAM_BUKA:02d}.00 - {JAM_TUTUP:02d}.00 WIB\n\n_Di luar jam operasional, pesan akan dibalas saat toko buka_ 😊", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def menu_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    keyboard = [[InlineKeyboardButton("🛒 Order Sekarang", callback_data="menu_produk")], [InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")]]
    await query.edit_message_text("🔥 *Cara Order:*\n\n1️⃣ Pilih produk\n2️⃣ Tap tombol Order\n3️⃣ Admin menghubungi kamu\n4️⃣ Lakukan pembayaran\n5️⃣ Akun langsung aktif! ⚡", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def menu_utama(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    keyboard = [
        [InlineKeyboardButton("🛒 Lihat Produk", callback_data="menu_produk")],
        [InlineKeyboardButton("❓ FAQ", callback_data="menu_faq"), InlineKeyboardButton("📞 Hubungi Admin", callback_data="menu_admin")],
        [InlineKeyboardButton("🔥 Cara Order", callback_data="menu_order")],
    ]
    await query.edit_message_text(f"🏠 *Menu Utama {NAMA_TOKO}*\n\nPilih menu di bawah:", parse_mode="Markdown", reply_markup=InlineKeyboardMarkup(keyboard))

async def pesan_masuk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    pesan = update.message.text
    if not jam_kerja():
        await update.message.reply_text(pesan_tutup(), parse_mode="Markdown")
        await context.bot.send_message(ADMIN_ID, f"💬 *Pesan masuk (luar jam kerja)*\n\n👤 {user.full_name} (@{user.username})\n📝 \"{pesan}\"", parse_mode="Markdown")
    else:
        keyboard = [[InlineKeyboardButton("🛒 Lihat Menu", callback_data="menu_produk")]]
        await update.message.reply_text("Halo! Ada yang bisa kami bantu? 😊\n\nKetik /start untuk menu lengkap:", reply_markup=InlineKeyboardMarkup(keyboard))
        await context.bot.send_message(ADMIN_ID, f"💬 *Pesan masuk*\n\n👤 {user.full_name} (@{user.username})\n📝 \"{pesan}\"", parse_mode="Markdown")

def main():
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(menu_produk, pattern="^menu_produk$"))
    app.add_handler(CallbackQueryHandler(menu_faq, pattern="^menu_faq$"))
    app.add_handler(CallbackQueryHandler(menu_admin, pattern="^menu_admin$"))
    app.add_handler(CallbackQueryHandler(menu_order, pattern="^menu_order$"))
    app.add_handler(CallbackQueryHandler(menu_utama, pattern="^menu_utama$"))
    app.add_handler(CallbackQueryHandler(detail_produk, pattern="^produk_"))
    app.add_handler(CallbackQueryHandler(order_produk, pattern="^order_"))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, pesan_masuk))
    print(f"✅ {NAMA_TOKO} berjalan...")
    app.run_polling()

if __name__ == "__main__":
    main()
