async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    keyboard = [
        [InlineKeyboardButton("🛒 Lihat Produk", callback_data="menu_produk")],
        [InlineKeyboardButton("❓ FAQ", callback_data="menu_faq"),
         InlineKeyboardButton("📞 Hubungi Admin", callback_data="menu_admin")],
        [InlineKeyboardButton("🔥 Cara Order", callback_data="menu_order")],
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    await update.message.reply_text(
        f"Halo *{user.first_name}* 👋\n\n"
        f"Selamat datang di *{NAMA_TOKO}*!\n"
        f"Kami menyediakan langganan premium dengan harga terjangkau & bergaransi 🔥\n\n"
        f"Pilih menu di bawah ya:",
        parse_mode="Markdown",
        reply_markup=reply_markup
    )

async def menu_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    keyboard = []
    for key, produk in PRODUK.items():
        keyboard.append([InlineKeyboardButton(
            f"{produk['emoji']} {produk['nama']}",
            callback_data=f"produk_{key}"
        )])
    keyboard.append([InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")])

    await query.edit_message_text(
        "🛒 *Pilih produk yang kamu mau:*",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

async def detail_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    key = query.data.replace("produk_", "")
    produk = PRODUK.get(key)

    if not produk:
        await query.edit_message_text("Produk tidak ditemukan.")
        return

    harga_text = "\n".join([f"  • {durasi}: *{harga}*" for durasi, harga in produk['harga'].items()])
    keyboard = [
        [InlineKeyboardButton(f"✅ Order {produk['nama']}", callback_data=f"order_{key}")],
        [InlineKeyboardButton("🔙 Kembali", callback_data="menu_produk")],
    ]

    await query.edit_message_text(
        f"{produk['emoji']} *{produk['nama']}*\n\n"
        f"_{produk['deskripsi']}_\n\n"
        f"💰 *Harga:*\n{harga_text}\n\n"
        f"Tap tombol di bawah untuk order!",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

async def order_produk(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    key = query.data.replace("order_", "")
    produk = PRODUK.get(key)

    if not jam_kerja():
        await query.edit_message_text(pesan_tutup(), parse_mode="Markdown")
        # Notif ke admin
        await context.bot.send_message(
            ADMIN_ID,
            f"📬 Ada order masuk di luar jam kerja!\n"
            f"User: {query.from_user.full_name} (@{query.from_user.username})\n"
            f"Produk: {produk['nama']}"
        )
        return

    user = query.from_user
    # Kirim notif ke admin
    await context.bot.send_message(
        ADMIN_ID,
        f"🔔 *ORDER BARU!*\n\n"
        f"👤 Nama: {user.full_name}\n"
        f"🆔 Username: @{user.username}\n"
        f"📦 Produk: {produk['emoji']} {produk['nama']}\n\n"
        f"Segera hubungi customer!",
        parse_mode="Markdown"
    )

    keyboard = [[InlineKeyboardButton("🔙 Menu Utama", callback_data="menu_utama")]]
    await query.edit_message_text(
        f"✅ *Order {produk['nama']} diterima!*\n\n"
        f"Admin kami akan segera menghubungi kamu untuk konfirmasi dan pembayaran.\n\n"
        f"Mohon tunggu sebentar ya 🙏",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

