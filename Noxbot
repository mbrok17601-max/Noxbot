    faq_text = ""
    for i, (pertanyaan, jawaban) in enumerate(FAQ, 1):
        faq_text += f"*{i}. {pertanyaan}*\n{jawaban}\n\n"

    keyboard = [[InlineKeyboardButton("🔙 Kembali", callback_data="menu_utama")]]
    await query.edit_message_text(
        f"❓ *FAQ - Pertanyaan Umum*\n\n{faq_text}",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

