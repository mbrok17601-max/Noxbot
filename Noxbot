PRODUK = {
    "capcut": {"nama": "CapCut Pro", "emoji": "🎬", "harga": {"1 Bulan": "Rp 15.000", "3 Bulan": "Rp 40.000", "1 Tahun": "Rp 130.000"}, "deskripsi": "Akses semua fitur premium CapCut termasuk template eksklusif, tanpa watermark, dan efek pro."},
